{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, email::text AS \"email!\", name, headline, timezone, language,\n                   role, password_hash,\n                   email_verified_at, totp_enabled_at, stripe_customer_id, created_at\n            FROM users\n            WHERE email ILIKE $1\n            ORDER BY created_at DESC\n            LIMIT $2\n            ",

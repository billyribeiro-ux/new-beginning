  "query": "\n            SELECT id, user_id, status,\n                   subtotal_cents, tax_cents, total_cents, currency,\n                   stripe_checkout_session_id, created_at\n            FROM orders\n            WHERE $1::text IS NULL OR status = $1\n            ORDER BY created_at DESC\n            LIMIT $2\n            ",

{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT event_id, event_type, received_at, processed_at, attempts, processing_error\n            FROM stripe_events\n            WHERE processed_at IS NULL\n              AND received_at < now() - make_interval(secs => $1)\n            ORDER BY received_at\n            LIMIT $2\n            ",

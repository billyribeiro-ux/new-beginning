  "query": "\n            SELECT id, user_id, kind, title, body, source, read_at, created_at\n            FROM notifications\n            WHERE user_id = $1\n              AND ($2 = FALSE OR read_at IS NULL)\n            ORDER BY created_at DESC\n            LIMIT $3\n            ",
